<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Left Panel: Date & Stats -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.1"
        android:orientation="vertical"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date Label"
            android:textColor="#A0AEC0"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Syncing..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_status_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please open app"
            android:textColor="#718096"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Vertical Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#3F444F"
        android:layout_marginHorizontal="10dp" />

    <!-- Right Panel: Current / Next Class Card -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.4"
        android:orientation="vertical"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/widget_class_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Classes Today"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_class_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enjoy your day! 🎉"
            android:textColor="#A0AEC0"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:maxLines="1" />

        <!-- Button Actions -->
        <LinearLayout
            android:id="@+id/widget_button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_btn_present"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/widget_button_present"
                android:gravity="center"
                android:text="PRESENT"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginRight="4dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/widget_btn_absent"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/widget_button_absent"
                android:gravity="center"
                android:text="ABSENT"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginLeft="4dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Marked Badge Status -->
        <TextView
            android:id="@+id/widget_marked_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#22C55E"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:maxLines="1" />
    </LinearLayout>
</LinearLayout>
